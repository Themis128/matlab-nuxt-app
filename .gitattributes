# Auto detect text files and perform LF normalization
* text=auto

# MATLAB files
*.m text eol=lf
*.mat binary

# Python files
*.py text eol=lf
*.pyc binary

# JavaScript/TypeScript files
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Configuration files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.config.* text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary

# Data files
*.csv text eol=lf
*.h5 binary
*.hdf5 binary
